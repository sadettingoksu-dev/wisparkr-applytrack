# Bu dosyayı kopyalayip ".env.local" olarak kaydet ve gercek degerlerini gir.
# .env.local asla GitHub'a yuklenmez (.gitignore'da).

# === Supabase ===
# Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# DIKKAT: service role key sadece sunucu tarafinda kullanilir, asla client'a/NEXT_PUBLIC_ ile paylasilmaz
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === Anthropic Claude ===
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# === Lemon Squeezy ===
# https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_VARIANT_PRO=
LEMONSQUEEZY_VARIANT_CAREER_COACH=

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
