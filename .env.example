# Bu dosyayı kopyalayip ".env.local" olarak kaydet ve gercek degerlerini gir.
# .env.local asla GitHub'a yuklenmez (.gitignore'da).
#
# NOT: Projenin calismasi icin .env.local SART. Klonladiktan sonra bu dosyayi
# .env.local olarak kopyalayip tum degerleri doldur (degerler proje sahibinde).

# === Supabase (ZORUNLU) ===
# Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# DIKKAT: service role key sadece sunucu tarafinda kullanilir, asla client'a/NEXT_PUBLIC_ ile paylasilmaz
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === Anthropic Claude (ZORUNLU - tum AI ozellikleri icin) ===
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Opsiyonel; bos birakilirsa kod varsayilani kullanir (claude-haiku-4-5-20251001)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# === Lemon Squeezy (ZORUNLU - odeme/abonelik icin) ===
# https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
# Webhook imzalama sirri: Lemon Squeezy > Settings > Webhooks (max 40 karakter)
LEMONSQUEEZY_WEBHOOK_SECRET=
# Urun variant ID'leri: Lemon Squeezy > Products > (urun) > Variant
LEMONSQUEEZY_VARIANT_PRO=
LEMONSQUEEZY_VARIANT_CAREER_COACH=

# === App (ZORUNLU) ===
# Lokal gelistirme: http://localhost:3000  |  Canli: https://www.wisparkr.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Inbound e-posta webhook (OPSIYONEL) ===
# Sadece gelen e-posta entegrasyonunu kullanacaksan gerekli; bos birakilabilir.
INBOUND_EMAIL_WEBHOOK_SECRET=
